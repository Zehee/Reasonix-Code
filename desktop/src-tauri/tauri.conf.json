{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reasonix Code",
  "version": "0.1.4",
  "identifier": "dev.reasonix-code.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Reasonix Code",
        "width": 1024,
        "height": 720,
        "minWidth": 480,
        "minHeight": 320,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0b0b0b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost http://127.0.0.1:* http://localhost:*; font-src 'self' data: http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' http://127.0.0.1:* http://localhost:*; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* https://api.deepseek.com https://pub-147fb53b9c1e4bbf891a257968619ea7.r2.dev https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../install.ps1": "install.ps1"
    },
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "languages": [
          "English",
          "SimpChinese"
        ],
        "customLanguageFiles": {
          "English": "nsis/English.nsh",
          "SimpChinese": "nsis/SimpChinese.nsh"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Zehee/Reasonix-Code/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
